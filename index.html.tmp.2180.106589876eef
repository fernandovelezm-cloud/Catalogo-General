g"], ["80589", "80589.jpg"], ["80590", "80590.jpg"], ["80591", "80591.jpg"], ["80592", "80592.jpg"], ["80593", "80593.jpg"], ["80594", "80594.jpg"], ["80595", "80595.jpg"], ["80596", "80596.jpg"], ["80597", "80597.jpg"], ["80598", "80598.jpg"], ["80599", "80599.jpg"], ["80600", "80600.jpg"], ["80601", "80601.jpg"], ["80602", "80602.jpg"], ["80604", "80604.jpg"], ["80606", "80606.jpg"], ["80607", "80607.jpg"], ["80608", "80608.jpg"], ["80609", "80609.jpg"], ["80611", "80611.jpg"], ["80612", "80612.jpg"], ["80615", "80615.jpg"], ["80616", "80616.jpg"], ["80619", "80619.jpg"], ["80620", "80620.jpg"], ["8172", "8172.jpg"], ["8187", "8187.jpg"], ["8229", "8229.jpg"], ["8260", "8260.jpg"], ["8264", "8264.jpg"], ["8275", "8275.jpg"], ["8279", "8279.jpg"], ["8282", "8282.jpg"], ["8288", "8288.jpg"], ["fila33_SIN_CODIGO", "fila33_SIN_CODIGO.jpg"]];

const grid = document.getElementById('grid');
const search = document.getElementById('search');
const count = document.getElementById('count');
const empty = document.getElementById('empty');
const overlay = document.getElementById('overlay');
const modalImg = document.getElementById('modalImg');
const modalCode = document.getElementById('modalCode');
const closeBtn = document.getElementById('closeBtn');
const prevBtn = document.getElementById('prevBtn');
const nextBtn = document.getElementById('nextBtn');

items.reverse();
let currentFiltered = items;
let currentIndex = -1;
let currentCat = 'todos';
let currentSub = 'todos';

const catBar = document.getElementById('catBar');
const subBar = document.getElementById('subBar');

function getCategory(code) {
  if (code.startsWith('8')) return { cat: 'bolsos', sub: null };
  if (code.startsWith('54')) return { cat: 'calzado', sub: 'tenis' };
  if (code.startsWith('57')) return { cat: 'calzado', sub: 'botines' };
  return { cat: null, sub: null };
}

function render() {
  grid.innerHTML = '';
  currentFiltered.forEach(([code, file], idx) => {
    const div = document.createElement('div');
    div.className = 'item';
    div.dataset.code = code.toLowerCase();
    div.innerHTML = `
      <div class="thumb-wrap"><img src="${file}" loading="lazy" alt="${code}"></div>
      <div class="code">${code}</div>
    `;
    div.addEventListener('click', () => openModal(idx));
    grid.appendChild(div);
  });
  count.textContent = currentFiltered.length + ' fotos';
  empty.classList.toggle('hidden', currentFiltered.length > 0);
  grid.classList.toggle('hidden', currentFiltered.length === 0);
}

function filter() {
  const q = search.value.trim().toLowerCase();
  currentFiltered = items.filter(([code]) => {
    if (q && !code.toLowerCase().includes(q)) return false;
    if (currentCat !== 'todos') {
      const { cat, sub } = getCategory(code);
      if (cat !== currentCat) return false;
      if (currentCat === 'calzado' && currentSub !== 'todos' && sub !== currentSub) return false;
    }
    return true;
  });
  render();
}

function openModal(idx) {
  currentIndex = idx;
  const [code, file] = currentFiltered[idx];
  modalImg.src = file;
  modalCode.textContent = code;
  overlay.classList.remove('hidden');
}

function closeModal() {
  overlay.classList.add('hidden');
}

function showRelative(delta) {
  if (currentIndex === -1 || currentFiltered.length === 0) return;
  const newIndex = (currentIndex + delta + currentFiltered.length) % currentFiltered.length;
  openModal(newIndex);
}

catBar.addEventListener('click', (e) => {
  const btn = e.target.closest('.cat-btn');
  if (!btn) return;
  currentCat = btn.dataset.cat;
  currentSub = 'todos';
  catBar.querySelectorAll('.cat-btn').forEach(b => b.classList.toggle('active', b === btn));
  subBar.classList.toggle('hidden', currentCat !== 'calzado');
  subBar.querySelectorAll('.sub-btn').forEach(b => b.classList.toggle('active', b.dataset.sub === 'todos'));
  filter();
});

subBar.addEventListener('click', (e) => {
  const btn = e.target.closest('.sub-btn');
  if (!btn) return;
  currentSub = btn.dataset.sub;
  subBar.querySelectorAll('.sub-btn').forEach(b => b.classList.toggle('active', b === btn));
  filter();
});

search.addEventListener('input', filter);
closeBtn.addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
prevBtn.addEventListener('click', () => showRelative(-1));
nextBtn.addEventListener('click', () => showRelative(1));
document.addEventListener('keydown', (e) => {
  if (overlay.classList.contains('hidden')) return;
  if (e.key === 'Escape') closeModal();
  if (e.key === 'ArrowLeft') showRelative(-1);
  if (e.key === 'ArrowRight') showRelative(1);
});

filter();
</script>
</body>
</html>
